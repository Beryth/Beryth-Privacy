{
  "manifest_version": 3,
  "name": "Beryth Privacy",
  "version": "0.1.0",
  "description": "Anti-tracking & anti-fingerprinting OPSEC toolkit.",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/injector.ts"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-context.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "src/ui/popup/index.html"
  },
  "options_page": "src/ui/options/index.html"
}
